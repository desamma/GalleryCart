@model GalleryCart.Areas.Artist.Models.CommissionManagementModel
@using GalleryCart.Utilities.Utils
@{
    ViewData["Title"] = "Manage Your Commissions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-base-200 p-4">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-4xl font-bold text-base-content mb-2">Manage Your Commissions</h1>
                <div class="text-sm breadcrumbs">
                    <ul>
                        <li><a href="/Artists/Home/Index" class="link link-hover">Dashboard</a></li>
                        <li class="text-base-content/60">Commissions</li>
                    </ul>
                </div>
            </div>
            <div class="stats shadow bg-base-100">
                <div class="stat place-items-center">
                    <div class="stat-title">Total</div>
                    <div class="stat-value text-2xl">@Model.Posts.Count()</div>
                </div>
                <div class="stat place-items-center">
                    <div class="stat-title">Pending</div>
                    <div class="stat-value text-2xl text-warning">@Model.Posts.Count(c => c.Status == "Pending")</div>
                </div>
                <div class="stat place-items-center">
                    <div class="stat-title">In Progress</div>
                    <div class="stat-value text-2xl text-info">@Model.Posts.Count(c => c.Status == "In Progress")</div>
                </div>
                <div class="stat place-items-center">
                    <div class="stat-title">Completed</div>
                    <div class="stat-value text-2xl text-success">@Model.Posts.Count(c => c.Status == "Completed")</div>
                </div>
            </div>
        </div>

        <!-- Success Message -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>@TempData["SuccessMessage"]</span>
            </div>
        }

        <!-- Status Filter Tabs -->
        <div class="tabs tabs-boxed mb-6 bg-base-100 shadow">
            <a class="tab tab-active" onclick="filterCommissions('all')">All</a>
            <a class="tab" onclick="filterCommissions('Pending')">Pending</a>
            <a class="tab" onclick="filterCommissions('In Progress')">In Progress</a>
            <a class="tab" onclick="filterCommissions('Completed')">Completed</a>
            <a class="tab" onclick="filterCommissions('Rejected')">Rejected</a>
        </div>

        <!-- Commissions List -->
        <div class="space-y-6">
            @foreach (var statusGroup in Model.Posts
            .GroupBy(c => c.Status)
            .OrderBy(g => Model.StatusOrder.ContainsKey(g.Key) ? Model.StatusOrder[g.Key] : 5))
            {
                <div class="status-group" data-status="@statusGroup.Key">
                    <!-- Status Header -->
                    <div class="flex items-center gap-4 mb-4">
                        <h2 class="text-2xl font-bold text-base-content">
                            @statusGroup.Key Commissions
                        </h2>
                        <div class="badge badge-outline badge-lg">@statusGroup.Count()</div>
                    </div>

                    <!-- Commissions in this Status -->
                    <div class="grid gap-4">
                        @foreach (var commission in statusGroup.OrderByDescending(c => c.CreatedDate))
                        {
                            <div class="commission-card card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-1" data-status="@commission.Status">
                                <div class="card-body p-6">
                                    <div class="flex flex-col lg:flex-row gap-6">
                                        <!-- Customer Info -->
                                        <div class="flex items-center gap-4 lg:w-1/4">
                                            <div class="avatar">
                                                <div class="w-12 h-12 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
                                                    <img src="@commission.Commissioner.UserAvatar" alt="@commission.Commissioner.UserName" />
                                                </div>
                                            </div>
                                            <div>
                                                <h3 class="font-bold text-base-content">@commission.Commissioner.UserName</h3>
                                                <p class="text-sm text-base-content/60">@commission.Commissioner.Email</p>
                                            </div>
                                        </div>

                                        <!-- Commission Details -->
                                        <div class="flex-1">
                                            <div class="mb-4">
                                                <h4 class="font-semibold text-base-content mb-2">Commission Description</h4>
                                                <p class="text-base-content/80 text-sm leading-relaxed line-clamp-3">
                                                    @commission.Description
                                                </p>
                                            </div>
                                                
                                            @if (commission.CommissionResultLink != null && commission.CommissionResultLink.Any())
                                            {
                                                <div class="mb-4 p-4 bg-base-200 rounded-lg">
                                                    <h5 class="font-semibold text-base-content mb-3 flex items-center">
                                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-2">
                                                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                                                        </svg>
                                                        Commission Results
                                                    </h5>

                                                    @{
                                                        var files = CommissionResultHelper.GetFiles(commission.CommissionResultLink);
                                                        var links = CommissionResultHelper.GetLinks(commission.CommissionResultLink);
                                                        var uploadedAt = CommissionResultHelper.GetUploadedAt(commission.CommissionResultLink);
                                                        var notes = commission.CommissionResultLink.FirstOrDefault(x => x.StartsWith("NOTES:"));
                                                    }

                                                    <!-- Display uploaded files -->
                                                    @if (files.Any())
                                                    {
                                                        <div class="mb-3">
                                                            <div class="text-sm font-medium text-base-content/80 mb-2">Uploaded Files:</div>
                                                            <div class="space-y-2">
                                                                @foreach (var file in files)
                                                                {
                                                                    <div class="flex items-center justify-between bg-base-100 p-2 rounded">
                                                                        <div class="flex items-center gap-2">
                                                                            @{
                                                                                var fileExtension = System.IO.Path.GetExtension(file.OriginalName).ToLowerInvariant();
                                                                                string fileIcon = "📄";
                                                                                if (new[] { ".jpg", ".jpeg", ".png", ".gif" }.Contains(fileExtension)) fileIcon = "🖼️";
                                                                                else if (fileExtension == ".pdf") fileIcon = "📑";
                                                                                else if (new[] { ".zip", ".rar" }.Contains(fileExtension)) fileIcon = "🗜️";
                                                                                else if (new[] { ".psd", ".ai" }.Contains(fileExtension)) fileIcon = "🎨";
                                                                            }
                                                                            <span class="text-lg">@fileIcon</span>
                                                                            <span class="text-sm font-medium">@file.OriginalName</span>
                                                                        </div>
                                                                        <a href="/uploads/commissions/@file.FilePath"
                                                                           target="_blank"
                                                                           class="btn btn-ghost btn-xs text-primary">
                                                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                                                                            </svg>
                                                                            Download
                                                                        </a>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }

                                                    <!-- Display external links -->
                                                    @if (links.Any())
                                                    {
                                                        <div class="mb-3">
                                                            <div class="text-sm font-medium text-base-content/80 mb-2">External Links:</div>
                                                            <div class="space-y-2">
                                                                @foreach (var link in links)
                                                                {
                                                                    <div class="flex items-center justify-between bg-base-100 p-2 rounded">
                                                                        <div class="flex items-center gap-2">
                                                                            <span class="text-lg">🔗</span>
                                                                            <span class="text-sm font-medium truncate">@link</span>
                                                                        </div>
                                                                        <a href="@link"
                                                                           target="_blank"
                                                                           rel="noopener noreferrer"
                                                                           class="btn btn-ghost btn-xs text-primary">
                                                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                                                            </svg>
                                                                            Open
                                                                        </a>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    <!-- Display upload timestamp -->
                                                    @if (uploadedAt.HasValue)
                                                    {
                                                        <div class="text-xs text-base-content/60 mt-2 flex items-center">
                                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                            </svg>
                                                            Uploaded on @uploadedAt.Value.ToString("MMM dd, yyyy 'at' hh:mm tt")
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 text-sm">
                                                <div>
                                                    <span class="text-base-content/60">Status</span>
                                                    <div class="mt-1">
                                                        @switch (commission.Status)
                                                        {
                                                            case "Pending":
                                                                <div class="badge badge-warning badge-sm">@commission.Status</div>
                                                                break;
                                                            case "In Progress":
                                                                <div class="badge badge-info badge-sm">@commission.Status</div>
                                                                break;
                                                            case "Completed":
                                                                <div class="badge badge-success badge-sm">@commission.Status</div>
                                                                break;
                                                            case "Rejected":
                                                                <div class="badge badge-error badge-sm">@commission.Status</div>
                                                                break;
                                                            default:
                                                                <div class="badge badge-ghost badge-sm">@commission.Status</div>
                                                                break;
                                                        }
                                                    </div>
                                                </div>
                                                <div>
                                                    <span class="text-base-content/60">Price (VND)</span>
                                                    <div class="font-bold text-success mt-1">$@commission.Price</div>
                                                </div>
                                                <div>
                                                    <span class="text-base-content/60">Created</span>
                                                    <div class="mt-1">@commission.CreatedDate.ToString("MMM dd, yyyy")</div>
                                                </div>
                                                <div>
                                                    <span class="text-base-content/60">Due Date</span>
                                                    <div class="mt-1 @(commission.DueDate < DateTime.Now && commission.Status != "Completed" ? "text-error font-semibold" : "")">
                                                        @commission.DueDate.ToString("MMM dd, yyyy")
                                                    </div>
                                                </div>
                                            </div>

                                            @if (commission.Status == "In Progress")
                                            {
                                                <div class="mt-4">
                                                    <div class="flex items-center gap-2 text-sm">
                                                        <span class="loading loading-spinner loading-sm text-primary"></span>
                                                        <span class="text-base-content/80 font-medium">Work in Progress</span>
                                                    </div>
                                                    <div class="mt-2 text-xs text-base-content/60">
                                                        Your commission is currently being worked on. We'll notify you when it's complete.
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <!-- Actions -->
                                        <div class="flex flex-col gap-2 lg:w-1/4 lg:items-end">
                                            @if (commission.Status == "Pending")
                                            {
                                                <div class="flex flex-col gap-2 w-full">
                                                    <form method="post" asp-action="Accept" asp-area="Artist" asp-controller="Commission" class="w-full">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="commissionId" value="@commission.CommissionId.ToString()" />
                                                        <button type="submit" class="btn btn-success btn-sm w-full">
                                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                            </svg>
                                                            Accept Commission
                                                        </button>
                                                    </form>

                                                    <button class="btn btn-error btn-sm w-full" onclick="openRejectModal('@commission.CommissionId', '@commission.Commissioner.UserName')">
                                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                                        </svg>
                                                        Reject
                                                    </button>
                                                </div>
                                            }
                                            else if (commission.Status == "In Progress")
                                            {
                                                <div class="flex flex-col gap-2 w-full">
                                                    <form method="post" asp-action="Complete" asp-controller="Commission" class="w-full">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="commissionId" value="@commission.CommissionId.ToString()" />
                                                        <button type="submit" class="btn btn-success btn-sm w-full">
                                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                            </svg>
                                                            Mark as Done
                                                        </button>
                                                    </form>
                                                </div>
                                            }

                                            <!-- Message Customer Button -->
                                            <a href="@Url.Action("Chat", "Chat", new { area = "Chat", id = commission.Commissioner.Id })" class="btn btn-ghost btn-sm w-full">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                                </svg>
                                                Message Customer
                                            </a>

                                            <div class="dropdown dropdown-end">
                                                <div tabindex="0" role="button" class="btn btn-ghost btn-sm w-full">
                                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
                                                    </svg>
                                                    More Actions
                                                </div>
                                                <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
                                                    <li><a href="@Url.Page("/Commission/Details", new {commissionId = commission.CommissionId})">View Details</a></li>
                                                    <li><a href="@Url.Action("/Commission/Edit", new {commissionId = commission.CommissionId})">Edit Commission</a></li>
                                                    @if (commission.Status == "Completed")
                                                    {
                                                        <li><a href="#" onclick="openUploadModal('@commission.CommissionId', '@commission.Commissioner.UserName')">Upload Files</a></li>
                                                    }
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Reject Commission Modal -->
<dialog id="rejectModal" class="modal">
    <div class="modal-box">
        <form method="dialog">
            <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
        </form>
        <h3 class="font-bold text-lg mb-4">Reject Commission</h3>
        <form method="post" asp-action="Reject" asp-controller="Commission" asp-area="Artist">
            @Html.AntiForgeryToken()
            <input type="hidden" id="rejectCommissionId" name="commissionId" />
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Reason for rejection (optional)</span>
                </label>
                <textarea name="rejectionReason" class="textarea textarea-bordered h-32" placeholder="Please provide a reason for rejecting this commission..."></textarea>
            </div>
            <div class="modal-action">
                <button type="submit" class="btn btn-error">Reject Commission</button>
                <button type="button" class="btn" onclick="document.getElementById('rejectModal').close()">Cancel</button>
            </div>
        </form>
    </div>
</dialog>

<!-- Upload Files Modal -->
<dialog id="uploadModal" class="modal">
    <div class="modal-box max-w-4xl">
        <form method="dialog">
            <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
        </form>
        <h3 class="font-bold text-lg mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 inline-block mr-2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
            </svg>
            Upload Files for <span id="uploadCustomerName" class="text-primary"></span>
        </h3>

        <form method="post" asp-action="UploadFiles" asp-controller="Commission" asp-area="Artist" enctype="multipart/form-data" id="uploadForm">
            @Html.AntiForgeryToken()
            <input type="hidden" id="uploadCommissionId" name="commissionId"/>

            <div class="space-y-6">
                <!-- File Upload Section -->
                <div class="form-control">
                    <label class="label">
                        <span class="label-text font-semibold">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 inline-block mr-1">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c-.621 0-1.125-.504-1.125-1.125V11.25a9 9 0 00-9-9z" />
                            </svg>
                            Upload Files
                        </span>
                        <span class="label-text-alt text-info">Supported: JPG, PNG, GIF, PDF, ZIP, RAR, PSD, AI (Max 50MB each)</span>
                    </label>
                    <input type="file" name="files" multiple class="file-input file-input-bordered w-full" accept=".jpg,.jpeg,.png,.gif,.pdf,.zip,.rar,.psd,.ai" onchange="updateFileList()" />
                    <div id="fileList" class="mt-2"></div>
                </div>

                <!-- External Links Section -->
                <div class="form-control">
                    <label class="label">
                        <span class="label-text font-semibold">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 inline-block mr-1">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                            </svg>
                            External Links
                        </span>
                        <span class="label-text-alt text-info">Google Drive, Dropbox, OneDrive, etc.</span>
                    </label>
                    <div id="linksContainer">
                        <div class="link-input-group flex gap-2 mb-2">
                            <input type="url" name="links" class="input input-bordered flex-1" placeholder="https://example.com/your-file-link" />
                            <button type="button" class="btn btn-outline btn-error btn-sm" onclick="removeLinkInput(this)" style="display: none;">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </div>
                    </div>
                    <button type="button" class="btn btn-outline btn-sm mt-2" onclick="addLinkInput()">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                        Add Another Link
                    </button>
                </div>

                <!-- Notes Section -->
                <div class="form-control">
                    <label class="label">
                        <span class="label-text font-semibold">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 inline-block mr-1">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                            </svg>
                            Additional Notes (Optional)
                        </span>
                    </label>
                    <textarea name="notes" class="textarea textarea-bordered h-24" placeholder="Any additional instructions or notes for the customer..."></textarea>
                </div>

                <!-- Upload Progress -->
                <div id="uploadProgress" class="hidden">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="loading loading-spinner loading-sm"></span>
                        <span class="text-sm">Uploading files...</span>
                    </div>
                    <progress class="progress progress-primary w-full" value="0" max="100"></progress>
                </div>
            </div>

            <div class="modal-action">
                <button type="submit" class="btn btn-primary" id="uploadBtn">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                    </svg>
                    Upload Files & Links
                </button>
                <button type="button" class="btn" onclick="document.getElementById('uploadModal').close()">Cancel</button>
            </div>
        </form>
    </div>
</dialog>

<script>
    // Fixed JavaScript code - replace the entire <script> section with this

    function openRejectModal(commissionId, customerName) {
        document.getElementById('rejectCommissionId').value = commissionId;
        document.getElementById('rejectModal').showModal();
    }

    function openUploadModal(commissionId, customerName) {
        document.getElementById('uploadCommissionId').value = commissionId;
        document.getElementById('uploadCustomerName').textContent = customerName;

        // Reset form
        document.getElementById('uploadForm').reset();
        document.getElementById('fileList').innerHTML = '';

        // Reset links container
        const linksContainer = document.getElementById('linksContainer');
        linksContainer.innerHTML = `
            <div class="link-input-group flex gap-2 mb-2">
                <input type="url" name="links" class="input input-bordered flex-1" placeholder="https://example.com/your-file-link" />
                <button type="button" class="btn btn-outline btn-error btn-sm" onclick="removeLinkInput(this)" style="display: none;">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        `;

        document.getElementById('uploadModal').showModal();
    }

    function updateFileList() {
        const fileInput = document.querySelector('input[type="file"]');
        const fileList = document.getElementById('fileList');

        if (fileInput && fileInput.files.length > 0) {
            let html = '<div class="bg-base-200 rounded-lg p-3 mt-2"><div class="text-sm font-semibold mb-2">Selected Files:</div>';

            Array.from(fileInput.files).forEach((file, index) => {
                const fileSize = (file.size / 1024 / 1024).toFixed(2);

                let fileIcon = '📄';
                if (file.type.startsWith('image/')) fileIcon = '🖼️';
                else if (file.type === 'application/pdf') fileIcon = '📑';
                else if (file.type.includes('zip') || file.type.includes('rar')) fileIcon = '🗜️';

                html += `
                    <div class="flex items-center justify-between py-2 px-2 bg-base-100 rounded mb-1 text-sm" data-file-index="${index}">
                        <div class="flex items-center gap-2 flex-1 min-w-0">
                            <span class="text-lg">${fileIcon}</span>
                            <span class="truncate font-medium">${file.name}</span>
                        </div>
                        <div class="flex items-center gap-2 text-xs text-base-content/60">
                            <span>${fileSize} MB</span>
                            <button type="button" class="btn btn-ghost btn-xs text-error" onclick="removeFile(${index})">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </div>
                    </div>
                `;
            });

            html += '</div>';
            fileList.innerHTML = html;
        } else if (fileList) {
            fileList.innerHTML = '';
        }
    }

    function removeFile(indexToRemove) {
        const fileInput = document.querySelector('input[type="file"]');
        if (!fileInput) return;

        const dt = new DataTransfer();
        Array.from(fileInput.files).forEach((file, index) => {
            if (index !== indexToRemove) {
                dt.items.add(file);
            }
        });

        fileInput.files = dt.files;
        updateFileList();
    }

    function addLinkInput() {
        const linksContainer = document.getElementById('linksContainer');
        if (!linksContainer) return;

        const linkInputGroup = document.createElement('div');
        linkInputGroup.className = 'link-input-group flex gap-2 mb-2';
        linkInputGroup.innerHTML = `
            <input type="url" name="links" class="input input-bordered flex-1" placeholder="https://example.com/your-file-link" />
            <button type="button" class="btn btn-outline btn-error btn-sm" onclick="removeLinkInput(this)">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        `;
        linksContainer.appendChild(linkInputGroup);
        updateRemoveButtons();
    }

    function removeLinkInput(button) {
        const linkInputGroup = button.closest('.link-input-group');
        if (linkInputGroup) {
            linkInputGroup.remove();
            updateRemoveButtons();
        }
    }

    function updateRemoveButtons() {
        const linkInputGroups = document.querySelectorAll('.link-input-group');
        const removeButtons = document.querySelectorAll('.link-input-group .btn-error');

        removeButtons.forEach((button) => {
            if (linkInputGroups.length > 1) {
                button.style.display = 'flex';
            } else {
                button.style.display = 'none';
            }
        });
    }

    function filterCommissions(status) {
        // Update active tab
        document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('tab-active'));

        // Find the clicked tab and make it active
        const clickedTab = Array.from(document.querySelectorAll('.tab')).find(tab =>
            tab.textContent.trim().toLowerCase() === status.toLowerCase() ||
            (status === 'all' && tab.textContent.trim().toLowerCase() === 'all')
        );

        if (clickedTab) {
            clickedTab.classList.add('tab-active');
        }

        const commissionCards = document.querySelectorAll('.commission-card');
        const statusGroups = document.querySelectorAll('.status-group');

        if (status === 'all') {
            commissionCards.forEach(card => card.style.display = 'block');
            statusGroups.forEach(group => group.style.display = 'block');
        } else {
            statusGroups.forEach(group => {
                if (group.dataset.status === status) {
                    group.style.display = 'block';
                } else {
                    group.style.display = 'none';
                }
            });
        }
    }

    function isValidUrl(string) {
        try {
            new URL(string);
            return true;
        } catch (_) {
            return false;
        }
    }

    function preventDefaults(e) {
        e.preventDefault();
        e.stopPropagation();
    }

    function highlight(e) {
        const fileInputContainer = e.currentTarget;
        fileInputContainer.classList.add('border-primary', 'bg-primary/5');
    }

    function unhighlight(e) {
        const fileInputContainer = e.currentTarget;
        fileInputContainer.classList.remove('border-primary', 'bg-primary/5');
    }

    function handleDrop(e) {
        const fileInput = document.querySelector('input[type="file"]');
        if (!fileInput) return;

        const dt = e.dataTransfer;
        const droppedFiles = dt.files;

        // Merge existing files with dropped files
        const existingFiles = Array.from(fileInput.files);
        const newFiles = Array.from(droppedFiles);

        const mergedDataTransfer = new DataTransfer();

        // Add existing files
        existingFiles.forEach(file => {
            mergedDataTransfer.items.add(file);
        });

        // Add new files
        newFiles.forEach(file => {
            mergedDataTransfer.items.add(file);
        });

        fileInput.files = mergedDataTransfer.files;
        updateFileList();
    }

    function setupDragAndDrop() {
        const fileInput = document.querySelector('input[type="file"]');
        if (!fileInput) return;

        const fileInputContainer = fileInput.closest('.form-control');
        if (!fileInputContainer) return;

        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            fileInputContainer.addEventListener(eventName, preventDefaults, false);
            document.body.addEventListener(eventName, preventDefaults, false);
        });

        ['dragenter', 'dragover'].forEach(eventName => {
            fileInputContainer.addEventListener(eventName, highlight, false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            fileInputContainer.addEventListener(eventName, unhighlight, false);
        });

        fileInputContainer.addEventListener('drop', handleDrop, false);
    }

    function handleFileInputChange() {
        const fileInput = document.querySelector('input[type="file"]');
        if (!fileInput) return;

        fileInput.addEventListener('change', function (e) {
            const allowedTypes = ['.jpg', '.jpeg', '.png', '.gif', '.pdf', '.zip', '.rar', '.psd', '.ai'];
            const maxSize = 50 * 1024 * 1024; // 50MB

            // Get existing files
            const existingFiles = Array.from(this.files);
            const validFiles = [];
            const invalidFiles = [];

            // Process new files
            existingFiles.forEach(file => {
                const fileExtension = '.' + file.name.split('.').pop().toLowerCase();

                if (!allowedTypes.includes(fileExtension)) {
                    invalidFiles.push(`${file.name} (invalid type)`);
                    return;
                }

                if (file.size > maxSize) {
                    invalidFiles.push(`${file.name} (too large)`);
                    return;
                }

                validFiles.push(file);
            });

            if (invalidFiles.length > 0) {
                alert(`The following files were not added:\n${invalidFiles.join('\n')}`);
            }

            // Update file input with valid files only
            if (validFiles.length !== this.files.length) {
                const dt = new DataTransfer();
                validFiles.forEach(file => {
                    dt.items.add(file);
                });
                this.files = dt.files;
            }

            updateFileList();
        });
    }
    function addMoreFilesButton() {
        const fileInputContainer = document.querySelector('input[type="file"]').closest('.form-control');

        // Create hidden file input for additional files
        const additionalFileInput = document.createElement('input');
        additionalFileInput.type = 'file';
        additionalFileInput.multiple = true;
        additionalFileInput.accept = '.jpg,.jpeg,.png,.gif,.pdf,.zip,.rar,.psd,.ai';
        additionalFileInput.style.display = 'none';
        additionalFileInput.id = 'additionalFiles';

        // Create "Add More Files" button
        const addMoreBtn = document.createElement('button');
        addMoreBtn.type = 'button';
        addMoreBtn.className = 'btn btn-outline btn-sm mt-2';
        addMoreBtn.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Add More Files
            `;

        // Add click handler for the button
        addMoreBtn.addEventListener('click', function () {
            additionalFileInput.click();
        });

        // Handle additional file selection
        additionalFileInput.addEventListener('change', function () {
            const mainFileInput = document.querySelector('input[type="file"][name="files"]');
            if (!mainFileInput || !this.files.length) return;

            const allowedTypes = ['.jpg', '.jpeg', '.png', '.gif', '.pdf', '.zip', '.rar', '.psd', '.ai'];
            const maxSize = 50 * 1024 * 1024; // 50MB

            // Get existing files from main input
            const existingFiles = Array.from(mainFileInput.files);
            const newFiles = Array.from(this.files);
            const validNewFiles = [];
            const invalidFiles = [];

            // Validate new files
            newFiles.forEach(file => {
                const fileExtension = '.' + file.name.split('.').pop().toLowerCase();

                if (!allowedTypes.includes(fileExtension)) {
                    invalidFiles.push(`${file.name} (invalid type)`);
                    return;
                }

                if (file.size > maxSize) {
                    invalidFiles.push(`${file.name} (too large)`);
                    return;
                }

                // Check for duplicates
                const isDuplicate = existingFiles.some(existingFile =>
                    existingFile.name === file.name && existingFile.size === file.size
                );

                if (isDuplicate) {
                    invalidFiles.push(`${file.name} (already added)`);
                    return;
                }

                validNewFiles.push(file);
            });

            if (invalidFiles.length > 0) {
                alert(`The following files were not added:\n${invalidFiles.join('\n')}`);
            }

            // Merge existing and new valid files
            if (validNewFiles.length > 0) {
                const dt = new DataTransfer();

                // Add existing files
                existingFiles.forEach(file => {
                    dt.items.add(file);
                });

                // Add new valid files
                validNewFiles.forEach(file => {
                    dt.items.add(file);
                });

                mainFileInput.files = dt.files;
                updateFileList();
            }

            // Clear the additional input for next use
            this.value = '';
        });

        // Add elements to DOM
        fileInputContainer.appendChild(additionalFileInput);
        fileInputContainer.appendChild(addMoreBtn);
    }

    function validateUploadForm() {
        const form = document.getElementById('uploadForm');
        if (!form) return;

        form.addEventListener('submit', function (e) {
            const fileInput = document.querySelector('input[type="file"]');
            const linkInputs = document.querySelectorAll('input[name="links"]');

            let hasFiles = fileInput && fileInput.files.length > 0;
            let hasValidLinks = false;

            linkInputs.forEach(input => {
                if (input.value.trim() && isValidUrl(input.value.trim())) {
                    hasValidLinks = true;
                }
            });

            if (!hasFiles && !hasValidLinks) {
                e.preventDefault();
                alert('Please select at least one file or provide at least one valid link.');
                return false;
            }

            if (fileInput) {
                for (let i = 0; i < fileInput.files.length; i++) {
                    const file = fileInput.files[i];
                    const maxSize = 50 * 1024 * 1024; // 50MB in bytes

                    if (file.size > maxSize) {
                        e.preventDefault();
                        alert(`File "${file.name}" is too large. Maximum file size is 50MB.`);
                        return false;
                    }
                }
            }

            return true;
        });
    }

    function setupUploadFormSubmission() {
        const uploadForm = document.getElementById('uploadForm');
        if (!uploadForm) return;

        uploadForm.addEventListener('submit', function (e) {
            const uploadBtn = document.getElementById('uploadBtn');
            const uploadProgress = document.getElementById('uploadProgress');
            const fileInput = document.querySelector('input[type="file"]');
            const linkInputs = document.querySelectorAll('input[name="links"]');

            let hasFiles = fileInput && fileInput.files.length > 0;
            let hasLinks = false;

            linkInputs.forEach(input => {
                if (input.value.trim()) {
                    hasLinks = true;
                }
            });

            if (!hasFiles && !hasLinks) {
                e.preventDefault();
                alert('Please select at least one file or provide at least one link.');
                return;
            }

            if (fileInput) {
                for (let i = 0; i < fileInput.files.length; i++) {
                    const file = fileInput.files[i];
                    const maxSize = 50 * 1024 * 1024; // 50MB in bytes

                    if (file.size > maxSize) {
                        e.preventDefault();
                        alert(`File "${file.name}" is too large. Maximum file size is 50MB.`);
                        return;
                    }
                }
            }

            if (uploadBtn) {
                uploadBtn.disabled = true;
                uploadBtn.innerHTML = `
                    <span class="loading loading-spinner loading-sm mr-1"></span>
                    Uploading...
                `;
            }

            if (uploadProgress) {
                uploadProgress.classList.remove('hidden');

                let progress = 0;
                const progressBar = uploadProgress.querySelector('progress');
                const interval = setInterval(() => {
                    progress += Math.random() * 15;
                    if (progress > 90) progress = 90;
                    if (progressBar) progressBar.value = progress;
                }, 200);

                setTimeout(() => {
                    clearInterval(interval);
                    if (progressBar) progressBar.value = 100;
                }, 3000);
            }
        });
    }

    // Initialize all functionality when DOM is loaded
    document.addEventListener('DOMContentLoaded', function () {
        setupDragAndDrop();
        handleFileInputChange();
        addMoreFilesButton();
        validateUploadForm();
        setupUploadFormSubmission();

        // Setup tab click handlers
        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', function (e) {
                e.preventDefault();
                const tabText = this.textContent.trim().toLowerCase();
                let status = tabText;

                if (tabText === 'all') status = 'all';
                else if (tabText === 'pending') status = 'Pending';
                else if (tabText === 'in progress') status = 'In Progress';
                else if (tabText === 'completed') status = 'Completed';
                else if (tabText === 'rejected') status = 'Rejected';

                filterCommissions(status);
            });
        });
    });
</script>

<style>
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .commission-card {
        border-left: 4px solid transparent;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .commission-card[data-status="Pending"] {
            border-left-color: #f59e0b;
        }

        .commission-card[data-status="In Progress"] {
            border-left-color: #3b82f6;
        }

        .commission-card[data-status="Completed"] {
            border-left-color: #10b981;
        }

        .commission-card[data-status="Rejected"] {
            border-left-color: #ef4444;
        }

        .commission-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }

    /* File input styling */
    .file-input::-webkit-file-upload-button {
        margin-right: 1rem;
    }

    /* Drag and drop styling */
    .form-control.border-primary {
        border: 2px dashed;
        border-radius: 0.5rem;
        padding: 1rem;
        transition: all 0.3s ease;
    }

    /* Modal backdrop blur */
    .modal-open .modal-backdrop {
        backdrop-filter: blur(4px);
    }

    /* Upload progress styling */
    #uploadProgress {
        animation: fadeIn 0.3s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* File list styling */
    #fileList .bg-base-200 {
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* Link input animations */
    .link-input-group {
        animation: slideIn 0.3s ease-out;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(-10px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Status filter tabs hover effect */
    .tab:hover {
        background-color: rgba(255, 255, 255, 0.1);
        transition: background-color 0.2s ease;
    }

    /* Commission stats hover effect */
    .stats .stat:hover {
        transform: scale(1.02);
        transition: transform 0.2s ease;
    }

    /* Button loading state improvements */
    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    /* Upload modal enhancements */
    .modal-box {
        max-height: 90vh;
        overflow-y: auto;
    }

    /* Responsive improvements */
    @@media (max-width: 768px) {
        .commission-card .card-body {
            padding: 1rem;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
        }

        .modal-box {
            margin: 1rem;
            max-width: calc(100vw - 2rem);
        }
    }
</style>

@functions {
    private int GetStatusOrder(string status)
    {
        return status switch
        {
            "Pending" => 1,
            "In Progress" => 2,
            "Completed" => 3,
            "Rejected" => 4,
            _ => 5
        };
    }
}