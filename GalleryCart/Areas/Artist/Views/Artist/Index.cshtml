@model GalleryCart.Models.ViewModels.UserProfileVM

@{
    ViewData["Title"] = "User Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-gray-900 text-white p-4">
    <!-- User Profile Section -->
    <div class="max-w-7xl mx-auto mb-8">
        <div class="flex flex-col lg:flex-row gap-6 bg-gray-800 rounded-lg p-6">
            <!-- User Avatar -->
            <div class="flex-shrink-0">
                <div class="w-48 h-48 rounded-lg overflow-hidden bg-gray-700">
                    @if (!string.IsNullOrEmpty(Model.UserAvatar))
                    {
                        <img src="@Model.UserAvatar" alt="@Model.UserName" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center">
                            <svg class="w-20 h-20 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                            </svg>
                        </div>
                    }
                </div>
            </div>

            <!-- User Information -->
            <div class="flex-grow grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Username -->
                <div>
                    <h3 class="text-lg font-semibold text-white mb-2">UserName</h3>
                    <p class="text-gray-400">@Model.UserName</p>
                </div>

                <!-- Phone -->
                <div>
                    <h3 class="text-lg font-semibold text-white mb-2">Phone</h3>
                    <p class="text-gray-400">@(Model.PhoneNumber ?? "Not provided")</p>
                </div>

                <!-- Date of Birth -->
                <div class="md:col-span-2">
                    <h3 class="text-lg font-semibold text-white mb-2">Date of birth</h3>
                    <p class="text-gray-400">
                        @if (Model.UserDOB.HasValue)
                        {
                            @Model.UserDOB.Value.ToString("dd/MM/yyyy")
                        }
                        else
                        {
                            <span>Not provided</span>
                        }
                    </p>
                </div>
            </div>

            <!-- Edit Button (only show for own profile) -->
            @if (Model.IsOwnProfile)
            {
                <div class="flex-shrink-0 self-start">
                    <a asp-area="Artist" asp-action="Edit" asp-controller="Artist">
                        <button class="btn btn-outline btn-sm">Edit</button>
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Favorite Posts Section -->
    <div class="max-w-7xl mx-auto">
        <div class="mb-6">
            <h2 class="text-2xl font-bold text-white border-b-2 border-white inline-block pb-1">
                @if (Model.IsOwnProfile)
                {
                    <span>Your favourite posts</span>
                }
                else
                {
                    <span>@Model.UserName's favourite posts</span>
                }
            </h2>
        </div>

        @if (Model.Posts.Any())
        {
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-7 gap-5">
                @foreach (var post in Model.Posts)
                {
                    var thumbnail = post.Path?.Split(',')?.FirstOrDefault();
                    <div class="group relative rounded-lg overflow-hidden shadow hover:shadow-xl transition-all duration-300 bg-gray-800 hover:bg-gray-700">
                        <div class="relative aspect-square overflow-hidden">

                            @if (post.IsImage)
                            {
                                <img src="@thumbnail"
                                     alt="@post.Title"
                                     class="w-full h-full object-cover transition duration-300
                                                            @(post.IsMature ? "filter blur-xl group-hover:blur-0" : "")" />
                            }
                            else
                            {
                                <video class="w-full h-full object-cover transition duration-300
                                                             @(post.IsMature ? "filter blur-xl group-hover:blur-0" : "")"
                                       poster="@thumbnail"
                                       preload="metadata"
                                       muted>
                                    <source src="@thumbnail" type="video/mp4" />
                                    Your browser does not support the video tag.
                                </video>
                            }

                            <!-- Labels -->
                            <div class="absolute top-2 left-2 space-y-1">
                                @if (post.IsMature)
                                {
                                    <span class="bg-red-600 text-white text-xs px-2 py-0.5 rounded">18+</span>
                                }
                                @if (post.IsPorfolio)
                                {
                                    <span class="bg-blue-600 text-white text-xs px-2 py-0.5 rounded">Portfolio</span>
                                }
                            </div>

                            <!-- Hover Overlay -->
                            <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-80 transition duration-300 opacity-0 group-hover:opacity-100 p-3 flex flex-col justify-between">
                                <!-- Top Info -->
                                <div>
                                    <h3 class="text-white font-bold text-sm truncate">@post.Title</h3>
                                    <p class="text-gray-300 text-xs mt-1 line-clamp-2">@post.Description</p>

                                    <!-- Tags -->
                                    @if (post.PostTags.Any())
                                    {
                                        <div class="flex flex-wrap gap-1 mt-2 text-xs">
                                            @foreach (var tag in post.PostTags.Take(2))
                                            {
                                                <span class="bg-gray-700 text-gray-300 px-2 py-0.5 rounded">@tag.TagName</span>
                                            }
                                            @if (post.PostTags.Count() > 2)
                                            {
                                                <span class="bg-gray-700 text-gray-300 px-2 py-0.5 rounded">+@(@post.PostTags.Count() - 2)</span>
                                            }
                                        </div>
                                    }
                                </div>

                                <!-- Bottom Bar -->
                                <div class="flex items-center justify-between mt-3 text-xs text-gray-300">
                                    <div class="flex gap-2">
                                        <span class="flex items-center gap-1">
                                            ❤️ @post.LikeCount
                                        </span>
                                        <span class="flex items-center gap-1">
                                            👎 @post.DislikeCount
                                        </span>
                                    </div>

                                    <a asp-area="Artist"
                                       asp-controller="Post"
                                       asp-action="Read"
                                       asp-route-id="@post.PostId"
                                       class="text-white font-semibold bg-gray-600 hover:bg-gray-500 px-2 py-1 rounded">
                                        👁 View
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                @if (Model.IsOwnProfile)
                {
                    <p>You haven't favorited any posts yet.</p>
                }
                else
                {
                    <p>@Model.UserName hasn't favorited any posts yet.</p>
                }
            </div>
        }

    </div>

    <!-- Pagination -->
    @if (Model.TotalPostsCount > Model.PageSize)
    {
        <div class="flex justify-center mt-8">
            <div class="btn-group">
                @if (Model.CurrentPage > 1)
                {
                    <a href="?userId=@Model.UserId&pageNumber=@(Model.CurrentPage - 1)&pageSize=@Model.PageSize" class="btn btn-outline">Previous</a>
                }

                @{
                    var totalPages = (int)Math.Ceiling((double)Model.TotalPostsCount / Model.PageSize);
                    var startPage = Math.Max(1, Model.CurrentPage - 2);
                    var endPage = Math.Min(totalPages, Model.CurrentPage + 2);
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <span class="btn btn-active">@i</span>
                    }
                    else
                    {
                        <a href="?userId=@Model.UserId&pageNumber=@i&pageSize=@Model.PageSize" class="btn btn-outline">@i</a>
                    }
                }

                @if (Model.HasMorePosts)
                {
                    <a href="?userId=@Model.UserId&pageNumber=@(Model.CurrentPage + 1)&pageSize=@Model.PageSize" class="btn btn-outline">Next</a>
                }
            </div>
        </div>
    }
    }
    else
    {
    <!-- No Posts Message -->
    <div class="text-center py-12">
        <div class="text-gray-400 text-lg">
            @if (Model.IsOwnProfile)
            {
                <p>You haven't favorited any posts yet.</p>
            }
            else
            {
                <p>@Model.UserName hasn't favorited any posts yet.</p>
            }
        </div>
    </div>
    }
</div>
</div>