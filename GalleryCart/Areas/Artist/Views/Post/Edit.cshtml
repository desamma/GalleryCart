@model GalleryCart.Models.Models.Post
@{
    ViewData["Title"] = "Edit Post";
    var tags = ViewBag.Tags as List<GalleryCart.Models.Models.Tag>;
    var selectedTags = ViewBag.SelectedTags as List<Guid>;
}

<h1 class="text-2xl font-bold mb-4">Edit Post</h1>

<form asp-action="Edit" method="post" enctype="multipart/form-data" class="space-y-4">
    <input type="hidden" asp-for="PostId" />

    <div>
        <label asp-for="Title" class="block text-sm font-medium text-gray-700">Title</label>
        <input asp-for="Title" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm" />
        <span asp-validation-for="Title" class="text-red-500 text-sm"></span>
    </div>

    <div>
        <label asp-for="Description" class="block text-sm font-medium text-gray-700">Description</label>
        <textarea asp-for="Description" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm"></textarea>
        <span asp-validation-for="Description" class="text-red-500 text-sm"></span>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700">Upload New Images (optional)</label>
        <input type="file" name="files" multiple accept=".jpg,.jpeg,.png,.webp,.gif" class="mt-1 block w-full" />
    </div>

    <div>
        <label asp-for="Price" class="block text-sm font-medium text-gray-700">Price</label>
        <input asp-for="Price" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm" />
        <span asp-validation-for="Price" class="text-red-500 text-sm"></span>
    </div>

    <div class="flex gap-4">
        <div class="flex items-center">
            <input asp-for="IsImage" type="checkbox" class="rounded border-gray-300" />
            <label asp-for="IsImage" class="ml-2 text-sm text-gray-700">This is an image post</label>
        </div>
        <div class="flex items-center">
            <input asp-for="IsPorfolio" type="checkbox" class="rounded border-gray-300" />
            <label asp-for="IsPorfolio" class="ml-2 text-sm text-gray-700">Show in portfolio</label>
        </div>
        <div class="flex items-center">
            <input asp-for="IsMature" type="checkbox" class="rounded border-gray-300" />
            <label asp-for="IsMature" class="ml-2 text-sm text-gray-700">Mature content</label>
        </div>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700">Select Tags</label>
        <div class="grid grid-cols-2 gap-2 mt-1">
            @foreach (var tag in tags)
            {
                <div class="flex items-center">
                    <input type="checkbox" name="SelectedTags" value="@tag.TagId"
                           class="rounded border-gray-300"
                           @(selectedTags != null && selectedTags.Contains(tag.TagId) ? "checked" : "") />
                    <span class="ml-2 text-sm text-gray-700">@tag.TagName</span>
                </div>
            }
        </div>
    </div>

    <div class="flex space-x-4">
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
            Save Changes
        </button>

        <form asp-action="Delete" method="post" class="inline">
            <input type="hidden" name="id" value="@Model.PostId" />
            <button type="submit" class="px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-md hover:bg-red-700"
                    onclick="return confirm('Are you sure you want to delete this post?');">
                Delete Post
            </button>
        </form>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
