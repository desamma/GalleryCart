@model GalleryCart.Models.ViewModels.CommissionPaginateVM
@{
   ViewData["Title"] = "Manage Commissions";
}

<div class="flex h-screen">
   @await Html.PartialAsync("_AdminSidebar")

   <div class="flex-1 bg-gray-800 p-6 overflow-auto">
      <div class="text-2xl font-bold mb-4">Manage Commissions</div>

      <table class="table w-full table-zebra">
         <thead>
         <tr>
            <th>Artist</th>
            <th>Commissioner</th>
            <th>Description</th>
            <th>Created</th>
            <th>Due</th>
            <th>Price</th>
            <th>Status</th>
         </tr>
         </thead>
         <tbody>
         @foreach (var item in Model.Commissions)
         {
            <tr>
               <td>@item.ArtistName</td>
               <td>@item.CommissionerName</td>
               <td>@item.Description</td>
               <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>
               <td>@item.DueDate.ToString("dd/MM/yyyy")</td>
               <td>$@item.Price</td>
               <td>
                  <span class="badge @(item.Status switch
                                     {
                                        "Pending" => "badge-info",
                                        "In Progress" => "badge-warning",
                                        "Completed" => "badge-success",
                                        "Rejected" => "badge-error",
                                        _ => "badge-neutral"
                                     })">
                     @item.Status
                  </span>
               </td>
            </tr>
         }
         </tbody>
      </table>
      <div class="mt-6 flex justify-center space-x-2">
         @for (int i = 1; i <= Model.TotalPages; i++)
         {
            <a asp-action="ManageCommission"
               asp-route-page="@i"
               class="btn btn-sm @(Model.CurrentPage == i ? "btn-primary" : "btn-ghost")">
               @i
            </a>
         }
      </div>
   </div>
</div>