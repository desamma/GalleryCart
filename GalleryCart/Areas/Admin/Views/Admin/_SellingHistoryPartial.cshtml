@model List<GalleryCart.Models.ViewModels.SellingHistoryDto>

<table class="table w-full">
   <thead>
   <tr>
      <th>Title (VND)</th>
      <th>Artist</th>
      <th>Price</th>
      <th>Purchase Date</th>
   </tr>
   </thead>
   <tbody>
   @foreach (var item in Model)
   {
      <tr>
         <td>@item.Title</td>
         <td>@item.Artist</td>
         <td>@item.Price</td>
         <td>@item.PurchaseDate.ToString("dd/MM/yyyy HH:mm")</td>
      </tr>
   }
   </tbody>
</table>