@model GalleryCart.Models.Models.Post

<div class="space-y-2">
   <h3 class="text-xl font-bold">@Model.Title</h3>
   <p>@Model.Description</p>
   <div>
      @if (Model.IsImage)
      {
         <img src="@Model.Path" class="w-full max-h-96 object-contain" />
      }
      else
      {
         <video controls class="w-full max-h-96">
            <source src="@Model.Path" type="video/mp4" />
         </video>
      }
   </div>
   <div class="text-sm text-gray-600">Posted on @Model.PostDate?.ToString("dd/MM/yyyy")</div>
</div>