@page
@model GalleryCart.Areas.Customer.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Your Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-base-200 p-4">
    <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl font-bold mb-8 text-base-content">Your Cart</h1>

        <a asp-area="Customer" asp-page="/Cart/Index">My Cart</a>

        @* Payment test message *@
        @if (!string.IsNullOrEmpty(Model.PaymentMessage))
        {
            <div class="alert alert-success my-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>@Model.PaymentMessage</span>
            </div>
        }

        @if (Model.CartUser?.CartItems?.Any() == true)
        {
            <div class="space-y-6">
                @foreach (var item in Model.CartUser.CartItems)
                {
                    <div class="card bg-base-100 shadow-lg flex flex-col md:flex-row items-center p-4 gap-4">
                        <div class="flex-1">
                            <h2 class="font-semibold text-lg text-base-content mb-2">
                                @item.Post.Title
                            </h2>
                            <div class="text-sm text-base-content/70 mb-1">
                                Artist: <span class="font-semibold">@item.Post.Artist?.UserName</span>
                            </div>
                            <div class="text-sm text-base-content/70 mb-1">
                                Price: <span class="font-semibold text-success">$@item.Post.Price</span>
                            </div>
                            <div class="text-xs text-base-content/60">
                                Created: @item.Post.CreatedDate.ToString("MMM dd, yyyy")
                            </div>
                        </div>
                        <form asp-area="Customer" asp-controller="Cart" asp-action="RemoveFromCart" method="post" class="ml-auto">
                            <input type="hidden" name="postId" value="@item.PostId" />
                            <button type="submit" class="btn btn-error btn-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" class="inline-block w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                                Remove
                            </button>
                        </form>
                    </div>
                }
            </div>
            <div class="mt-8 flex justify-between items-center">
                <div class="text-xl font-bold text-base-content">
                    Total: $@(Model.CartUser.CartItems.Sum(i => i.Post?.Price ?? 0))
                </div>
                <div class="flex gap-2">
                    <form method="post" asp-page-handler="Checkout">
                        <button type="submit" class="btn btn-primary">Checkout</button>
                    </form>
                    <!-- Pay Now button: POST to PaymentController with PaymentInformationModel -->
                    <form method="post" action="/Customer/Payment/CreatePaymentUrlVnpay">
                        <input type="hidden" name="OrderType" value="billpayment" />
                        <input type="hidden" name="Amount" value="@(Model.CartUser.CartItems.Sum(i => i.Post?.Price ?? 0))" />
                        <input type="hidden" name="OrderDescription" value="Cart payment" />
                        <input type="hidden" name="Name" value="@User.Identity?.Name" />
                        <button type="submit" class="btn btn-success">Pay Now</button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="text-center text-base-content/60 py-12">
                <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <h3 class="text-xl font-semibold mb-2">Your cart is empty</h3>
                <p>Add some posts to your cart to get started.</p>
            </div>
        }

        @* Always show Pay Now button for testing, even if cart is empty *@
        <div class="mt-8 flex justify-center">
            <form method="post" action="/Customer/Payment/CreatePaymentUrlVnpay">
                <input type="hidden" name="OrderType" value="billpayment" />
                <input type="hidden" name="Amount" value="@(Model.CartUser?.CartItems?.Sum(i => i.Post?.Price ?? 0) ?? 0)" />
                <input type="hidden" name="OrderDescription" value="Cart payment" />
                <input type="hidden" name="Name" value="@User.Identity?.Name" />
                <button type="submit" class="btn btn-success">Pay Now</button>
            </form>
        </div>
    </div>
</div>