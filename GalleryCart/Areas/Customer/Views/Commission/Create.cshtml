@{
    ViewData["Title"] = "Commission Form";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model GalleryCart.Areas.Customer.Models.CreateCommssionViewModel

<div class="min-h-screen bg-gray-800 text-white font-sans p-5">
    <div class="max-w-2xl mx-auto bg-gray-700 rounded-lg p-8 shadow-2xl">
        <h1 class="text-2xl font-semibold mb-8 text-white">Commission Form</h1>

        <!-- Artist Information Card -->
        @if (Model.Artist != null)
        {
            <div class="card bg-base-200 shadow-xl mb-8 border border-gray-600">
                <div class="card-body p-6">
                    <div class="flex items-start gap-4">
                        <!-- Artist Avatar/Image -->
                        <div class="avatar">
                            <div class="w-16 h-16 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
                                @if (!string.IsNullOrEmpty(Model.Artist.UserAvatar))
                                {
                                    <img src="@Model.Artist.UserAvatar" alt="@Model.Artist.UserName" class="w-full h-full object-cover rounded-full" />
                                }
                                else
                                {
                                    <div class="w-full h-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-primary-content font-bold text-xl">
                                        @Model.Artist.UserName?.Substring(0, 1).ToUpper()
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Artist Details -->
                        <div class="flex-1">
                            <h2 class="card-title text-lg mb-2 text-white">
                                @Model.Artist.UserName
                                @*  @if (Model.Artist.IsVerified)
                            {
                            <div class="badge badge-primary badge-sm">
                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            Verified
                            </div>
                            } *@
                            </h2>

                            @if (!string.IsNullOrEmpty(Model.Artist.ProfessionSummary))
                            {
                                <p class="text-sm text-gray-300 mb-3 line-clamp-2">@Model.Artist.ProfessionSummary</p>
                            }

                            <div class="flex flex-wrap gap-2 mb-3">
                                @if (!string.IsNullOrEmpty(Model.Artist.Skills))
                                {
                                    <div class="badge badge-outline badge-sm">@Model.Artist.Skills</div>
                                }
                                @*  @if (Model.Artist.Rating.HasValue)
                            {
                            <div class="flex items-center gap-1 text-xs text-yellow-400">
                            <svg class="w-3 h-3 fill-current" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                            @Model.Artist.Rating.Value.ToString("F1")
                            </div>
                            } *@
                                @*
                            @if (Model.Artist.CompletedCommissions.HasValue)
                            {
                            <div class="badge badge-ghost badge-sm">
                            @Model.Artist.CompletedCommissions.Value commissions completed
                            </div>
                            } *@
                            </div>
                            @*   @if (Model.Artist.ResponseTime.HasValue)
                        {
                        <div class="text-xs text-gray-400">
                        <span class="inline-flex items-center gap-1">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                        </svg>
                        Usually responds within @Model.Artist.ResponseTime.Value hours
                        </span>
                        </div>
                        } *@
                        </div>
                    </div>
                </div>
            </div>
        }

        <form asp-action="Create" method="post" asp-controller="Commission" asp-area="Customer">
            @Html.AntiForgeryToken()

            <!-- Description Field -->
            <div class="mb-6">
                <label class="block text-sm font-medium mb-2 text-white">Description</label>
                <div class="relative">
                    <textarea class="w-full p-3 bg-gray-800 border border-gray-500 rounded-md text-white text-sm placeholder-gray-400 min-h-[120px] resize-y focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-blue-400 transition-colors duration-200"
                              placeholder="How do you describe your needed?..."
                              asp-for="@Model.Description"
                              maxlength="512"
                              oninput="updateCharCount(this)"></textarea>
                    <span class="absolute bottom-2 right-3 text-xs text-gray-400 bg-gray-800 px-1 rounded" id="charCounter">0/512</span>
                </div>
            </div>

            <!-- Price Field -->
                <div class="mb-6">
                    <label class="block text-sm font-medium mb-2 text-white">Price</label>
                    <input asp-for="@Model.Price"
                           type="number"
                           min="0"
                           class="w-24 p-3 bg-gray-800 border border-gray-500 rounded-md text-white text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-blue-400 transition-colors duration-200"
                           placeholder="0..." />
                </div>

            <!-- Deadline Field -->
                <div class="mb-6">
                    <label class="block text-sm font-medium mb-2 text-white">Deadline</label>
                    <div class="flex items-center gap-3">
                        <input asp-for="@Model.DueDateDays"
                               type="number"
                               min="1"
                               class="w-20 p-3 bg-gray-800 border border-gray-500 rounded-md text-white text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-blue-400 transition-colors duration-200"
                               placeholder="30..." />
                        <span class="text-white text-sm">Days</span>
                    </div>
                </div>

@*             <input type="hidden" asp-for="ArtistId" value="@ViewBag.ArtistId" /> *@

            <!-- Submit Button -->
            <div class="flex justify-end">
                <button type="submit"
                        class="btn btn-primary">
                    Send Commission Request
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function updateCharCount(textarea) {
        const counter = document.getElementById('charCounter');
        const current = textarea.value.length;
        const max = textarea.maxLength;
        counter.textContent = current + '/' + max;
        if (current > max * 0.9) {
            counter.classList.remove('text-gray-400');
            counter.classList.add('text-red-400');
        } else {
            counter.classList.remove('text-red-400');
            counter.classList.add('text-gray-400');
        }
    }
</script>