@model GalleryCart.Models.ViewModels.ProfileInputModel

@{
    ViewData["Title"] = "Edit Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-3xl mx-auto mt-10 bg-gray-800 rounded-lg shadow-lg p-6 space-y-6 text-white">
    <h2 class="text-2xl font-bold text-center mb-4">User Profile</h2>
    @*<p>UserName: @Model.Input.UserName</p>*@
    <form method="post" asp-antiforgery="true" asp-action="Edit" enctype="multipart/form-data" class="space-y-4" id="artistProfileForm">
        <div>
            <label asp-for="UserName" class="label-text">Username</label>
            <input asp-for="UserName" class="input input-bordered w-full text-black bg-white" />
            <span asp-validation-for="UserName" class="text-error text-sm"></span>
        </div>

        <div>
            <label asp-for="UserDOB" class="label-text">Date of Birth</label>
            <input asp-for="UserDOB" type="date" class="input input-bordered w-full text-black bg-white"
                   max="@DateTime.Now.ToString("yyyy-MM-dd")"/>
            <span asp-validation-for="UserDOB" class="text-error text-sm"></span>
        </div>

        <div>
            <label asp-for="PhoneNumber" class="label-text">Phone Number</label>
            <input asp-for="PhoneNumber" class="input input-bordered w-full text-black bg-white" />
            <span asp-validation-for="PhoneNumber" class="text-error text-sm"></span>
        </div>
        
        <div class="flex items-center gap-4">
            <label for="changeProfile" class="hover:scale-105 duration-150 transition-all hover:cursor-pointer">
                <input type="hidden" name="UserAvatar" asp-for="UserAvatar" value="@Model.UserAvatar" />
                <input type="file" name="image" id="changeProfile" style="display: none" accept=".jpg, .jpeg, .png, .gif, .bmp, .gif"/>
                <img src="@Model.UserAvatar" alt="User's Name" id="avatar"
                     class="avatar w-40 h-40 object-cover rounded-full shadow-md" />
            </label>
    
            <label for="changeProfile" id="uploadBtn"
                   class="bg-slate-900 text-white flex gap-2 items-center justify-center rounded px-4 py-2 text-sm hover:bg-slate-600 cursor-pointer">
                &#x270E; Edit
            </label>
        </div>

        <div class="flex justify-between">
            <button type="submit" class="btn btn-primary" id="artistUpdateBtn" disabled>Update</button>
        </div>
    </form>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mt-4">
            @TempData["Success"]
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Store original form values
            let originalFormData = {};
            let hasChanges = false;
            
            // Capture initial form state
            function captureOriginalState() {
                $('#artistProfileForm input, #artistProfileForm textarea, #artistProfileForm select').each(function() {
                    if ($(this).attr('type') === 'checkbox') {
                        originalFormData[$(this).attr('name') || $(this).attr('id')] = $(this).is(':checked');
                    } else if ($(this).attr('type') !== 'file') {
                        originalFormData[$(this).attr('name') || $(this).attr('id')] = $(this).val();
                    }
                });
            }
            
            // Check if form has changes
            function checkForChanges() {
                hasChanges = false;
                
                $('#artistProfileForm input, #artistProfileForm textarea, #artistProfileForm select').each(function() {
                    let fieldName = $(this).attr('name') || $(this).attr('id');
                    let currentValue;
                    
                    if ($(this).attr('type') === 'checkbox') {
                        currentValue = $(this).is(':checked');
                    } else if ($(this).attr('type') === 'file') {
                        // For file inputs, check if a file is selected
                        if ($(this)[0].files && $(this)[0].files.length > 0) {
                            hasChanges = true;
                            return false; // Break out of each loop
                        }
                        return true; // Continue to next iteration
                    } else {
                        currentValue = $(this).val();
                    }
                    
                    if (originalFormData[fieldName] !== currentValue) {
                        hasChanges = true;
                        return false; // Break out of each loop
                    }
                });
                
                // Enable/disable update button based on changes
                $('#artistUpdateBtn').prop('disabled', !hasChanges);
                
                // Optional: Change button appearance
                if (hasChanges) {
                    $('#artistUpdateBtn').removeClass('btn-disabled').addClass('btn-primary');
                } else {
                    $('#artistUpdateBtn').removeClass('btn-primary').addClass('btn-disabled');
                }
            }
            
            // Initialize original state
            captureOriginalState();
            
            // Monitor form changes
            $('#artistProfileForm').on('input change', 'input, textarea, select', function() {
                checkForChanges();
            });
            
            // Handle file input change for avatar
            $("#changeProfile").on("change", function (event) {
                const file = event.target.files[0];
                if (file) {
                    const tempUrl = URL.createObjectURL(file);
                    $("#avatar").attr("src", tempUrl);
                }
                checkForChanges();
            });
            
            window.resetForm = function() {
                $('#artistProfileForm')[0].reset();
                captureOriginalState();
                checkForChanges();
            };
        });
    </script>
    @* Change picture realtime *@
    <script>
        $("#changeProfile").on("change", function (event) {
            const file = event.target.files[0];
            const tempUrl = URL.createObjectURL(file);
            $("#avatar").attr("src", tempUrl);
        });
    </script>
}
