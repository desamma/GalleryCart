@model GalleryCart.Models.Models.Post
@using Microsoft.AspNetCore.Identity
@inject UserManager<GalleryCart.Models.Models.User> UserManager

@{
    ViewData["Title"] = "Post Detail";
    var currentUserId = UserManager.GetUserId(User);
    var isOwner = currentUserId == Model.UserId.ToString();
    var images = Model.Path?.Split(",") ?? new string[0];
    var favCount = ViewBag.FavouriteCount as int? ?? 0;
    var isFavourited = ViewBag.IsFavourited as bool? ?? false;
}

<div class="min-h-screen bg-[#0e0e0e] text-white px-4 py-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6">

        <!-- LEFT: Media Preview -->
        <div class="lg:col-span-8 max-h-[80vh] overflow-y-auto space-y-4">
            @foreach (var img in images)
            {
                if (Model.IsImage)
                {
                    <img src="@img"
                         alt="Post Image"
                         loading="lazy"
                         class="w-full object-cover rounded-xl shadow transition"
                         style="filter: blur(@((Model.IsMature && !isOwner) ? "5px" : "0"));" />
                }
                else
                {
                    <video controls
                           class="w-full rounded-xl shadow"
                           style="filter: blur(@((Model.IsMature && !isOwner) ? "5px" : "0"));">
                        <source src="@img" type="video/mp4" />
                    </video>
                }
            }
        </div>

        <!-- RIGHT: Info, Actions & Comments -->
        <div class="lg:col-span-4 flex flex-col space-y-6">

            <!-- Title & Author -->
            <div>
                <h1 class="text-2xl font-bold">@Model.Title</h1>
                <p class="text-sm text-gray-400 mt-1">
                    By <span class="font-semibold">@Model.User?.UserName</span> · @Model.PostDate?.ToString("dd/MM/yyyy")
                </p>
            </div>

            <!-- Tags -->
            <div>
                <h3 class="text-gray-300 font-semibold">Tags:</h3>
                <div class="flex flex-wrap gap-2 mt-1">
                    @foreach (var tag in Model.Tags)
                    {
                        <span class="bg-blue-800 text-xs px-3 py-1 rounded-full">@tag.TagName</span>
                    }
                </div>
            </div>

            <!-- Description -->
            <div>
                <h3 class="text-gray-300 font-semibold">Description:</h3>
                <p class="text-gray-200 mt-1 whitespace-pre-line">@Model.Description</p>
            </div>

            <!-- Price & Stats -->
            <div class="text-gray-300">
                <span class="text-yellow-400 font-bold text-lg">@Model.Price VND</span>
                <span class="ml-4">Sold: @Model.SaleCount</span>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-wrap gap-2">
                <!-- Favourite Count (hiển thị như Like) -->
                <div class="bg-blue-600 px-3 py-1 rounded-md text-sm flex items-center text-white">
                    ❤️ @favCount
                </div>

                <!-- Add to cart -->
                <form method="post" asp-area="Customer" asp-controller="Cart" asp-action="AddToCart">
                    <input type="hidden" name="postId" value="@Model.PostId" />
                    <button type="submit"
                            class="bg-green-600 hover:bg-green-700 px-3 py-1 rounded-md text-sm">
                        💾 Add to Cart
                    </button>
                </form>

                <!-- Favourite Toggle -->
                <form method="post" asp-action="Favourite" asp-route-id="@Model.PostId">
                    <button type="submit"
                            class="@(isFavourited ? "bg-pink-700" : "bg-pink-600") hover:bg-pink-800 px-3 py-1 rounded-md text-sm text-white">
                        @(isFavourited ? "💔 Unfavourite" : "⭐ Favourite")
                    </button>
                </form>
            </div>

            <!-- Owner Tools -->
            @if (isOwner)
            {
                <div class="flex gap-2 pt-3 border-t border-gray-600 mt-4">
                    <a asp-action="Create" asp-route-id="@Model.PostId"
                       class="bg-yellow-600 hover:bg-yellow-700 px-3 py-1 rounded text-sm">
                        ✏️ Edit
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.PostId" method="post">
                        <button type="submit"
                                class="bg-red-600 hover:bg-red-700 px-3 py-1 rounded text-sm">
                            🗑️ Delete
                        </button>
                    </form>
                </div>
            }

            <!-- Comments -->
            <div class="pt-6 border-t border-gray-600">
                <h2 class="text-lg font-semibold mb-3">Comments</h2>

                @if (Model.Comments != null && Model.Comments.Any())
                {
                    <div class="space-y-3 max-h-60 overflow-y-auto pr-1">
                        @foreach (var comment in Model.Comments.OrderByDescending(c => c.CommentDate))
                        {
                            <div class="bg-gray-800 rounded-lg p-3">
                                <div class="text-sm text-gray-400 mb-1">
                                    @comment.User?.UserName · @comment.CommentDate?.ToString("dd/MM/yyyy HH:mm")
                                </div>
                                <div class="text-white">@comment.Content</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-gray-500">No comments yet.</p>
                }

                <!-- Comment form -->
                <form method="post" asp-action="AddComment" asp-route-id="@Model.PostId" class="mt-4">
                    <textarea name="Content"
                              rows="3"
                              required
                              class="w-full p-3 bg-gray-900 border border-gray-700 rounded resize-none text-white"
                              placeholder="Write a comment..."></textarea>
                    <button type="submit"
                            class="mt-2 bg-blue-600 hover:bg-blue-700 px-4 py-2 text-white rounded">
                        Submit
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
