@using GalleryCart.DataAccess.Repository.IRepository;
@using GalleryCart.Models.Models;
@model GalleryCart.Models.ViewModels.IndexModel;
@inject IUserRepository UserRepository
@{
    ViewData["Title"] = "Customer Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="min-h-screen bg-gray-900 text-white">
    <!-- Banner Image -->
    <div class="relative w-full h-32 md:h-40 lg:h-48 overflow-hidden">
        <img src="https://nftnow.com/wp-content/uploads/2022/02/Nyan-Cat-Banner-700x394.png" alt="Join us bro banner" class="w-full h-full object-cover object-center" />

        <div class="absolute inset-0 bg-opacity-30 flex items-center justify-end">
            <h1 class="text-4xl font-bold text-white drop-shadow-lg">Join us bro</h1>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container mx-auto px-4 py-8">
        <!-- Posts Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-7 gap-4">
            @if (Model != null && Model.Posts.Any())
            {
                @foreach (var post in Model.Posts)
                {
                    if (post.User == null)
                        post.User = await UserRepository.GetAsync(a => a.Id.Equals(post.UserId));
                    if (post == null || post.User == null || string.IsNullOrEmpty(post.Path) || string.IsNullOrEmpty(post.Title) || post.Price <= 0)
                        continue; // Skip invalid posts
                    <div class="group relative">
                        <!-- Post Card -->
                        <div class="bg-gray-800 rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 group-hover:scale-105">
                            <!-- Post Image Container -->
                            <div class="relative aspect-square overflow-hidden">
                                @if (post.IsImage)
                                {
                                    <img src="@post.Path" alt="@post.Title" class="w-full h-full object-cover @(post.IsMature ? "mature-image" : "")" />
                                }
                                else
                                {
                                    <video class="w-full h-full object-cover @(post.IsMature ? "mature-image" : "")" poster="@post.Path" preload="metadata">
                                        <source src="@post.Path" type="video/mp4">
                                        Your browser does not support the video tag.
                                    </video>
                                    <!-- Video Play Icon -->
                                    <div class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-30 group-hover:bg-opacity-50 transition-all duration-300">
                                        <div class="w-12 h-12 bg-white bg-opacity-80 rounded-full flex items-center justify-center">
                                            <svg class="w-6 h-6 text-gray-800 ml-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M6.3 2.841A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />
                                            </svg>
                                        </div>
                                    </div>
                                }

                                <!-- Always visible badges -->
                                <div class="absolute top-2 left-2 flex flex-col space-y-1">
                                    @if (post.IsMature)
                                    {
                                        <div class="bg-red-600 text-white text-xs px-2 py-1 rounded">
                                            18+
                                        </div>
                                    }
                                    @if (post.IsPorfolio)
                                    {
                                        <div class="bg-blue-600 text-white text-xs px-2 py-1 rounded">
                                            Portfolio
                                        </div>
                                    }
                                </div>

                                <!-- Price Badge - Always visible -->
                                <div class="absolute top-2 right-2 bg-green-600 text-white text-xs px-2 py-1 rounded font-semibold">
                                    $@post.Price.ToString("F2")
                                </div>

                                <!-- Hover Overlay -->
                                <div class="absolute inset-0 bg-black bg-opacity-70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-between p-4">
                                    <a asp-action="ArtistProfile" asp-controller="Guest" asp-route-userId="@post.UserId" class="flex items-center space-x-3 hover:bg-gray-800 hover:bg-opacity-50 rounded-lg p-2 transition-colors duration-200 cursor-pointer">
                                        <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center">
                                            <span class="text-white font-bold text-sm">@post.User.UserName?.Substring(0, 1).ToUpper()</span>
                                        </div>
                                        <div>
                                            <h4 class="text-white font-semibold text-sm">@post.User.UserName</h4>
                                            <p class="text-gray-300 text-xs">Artist</p>
                                        </div>
                                    </a>

                                    <!-- Post Info - Bottom -->
                                    <div class="space-y-3">
                                        <!-- Post Title -->
                                        <h3 class="text-white font-semibold text-sm line-clamp-2">
                                            @post.Title
                                        </h3>

                                        <!-- Post Description -->
                                        <p class="text-gray-300 text-xs line-clamp-2">
                                            @post.Description
                                        </p>

                                        <!-- Post Stats -->
                                        <div class="flex items-center justify-between text-xs text-gray-300">
                                            <div class="flex items-center space-x-3">
                                                <!-- Like Count -->
                                                <div class="flex items-center space-x-1">
                                                    <svg class="w-3 h-3 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
                                                    </svg>
                                                    <span>@post.LikeCount</span>
                                                </div>

                                                <!-- Sale Count -->
                                                <div class="flex items-center space-x-1">
                                                    <svg class="w-3 h-3 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                                                        <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z" />
                                                    </svg>
                                                    <span>@post.SaleCount</span>
                                                </div>
                                            </div>

                                            <!-- Post Date -->
                                            <span class="text-gray-400">
                                                @post.PostDate?.ToString("MMM dd")
                                            </span>
                                        </div>

                                        <!-- Action Buttons -->
                                        <div class="flex items-center space-x-2">
                                            <a asp-area="Identity" asp-page="/Account/Register"
                                               class="flex-1 bg-gray-700 hover:bg-gray-600 text-white text-xs py-2 px-3 rounded transition-colors duration-200 flex items-center justify-center space-x-1 cursor-pointer">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                                </svg>
                                                <span>View</span>
                                            </a>

                                            <!-- Uncomment and add route parameter if needed -->
                                            <!-- <a asp-page="/BuyPage" asp-route-id="@post.PostId" class="bg-blue-600 hover:bg-blue-700 text-white text-xs py-2 px-4 rounded transition-colors duration-200 cursor-pointer">
                                                Buy
                                            </a> -->
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- Empty State -->
                <div class="col-span-full text-center py-12">
                    <div class="text-gray-500 mb-4">
                        <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-300 mb-2">No posts found</h3>
                    <p class="text-gray-500">There are no posts to display at the moment.</p>
                </div>
            }
        </div>

        <!-- Load More Button -->
        @if (Model != null && Model.Posts.Any())
        {
            <div class="text-center mt-8">
                <button class="bg-gray-700 hover:bg-gray-600 text-white px-6 py-3 rounded-lg transition-colors duration-200">
                    Load More Posts
                </button>
            </div>
        }
    </div>
</div>

<!-- Custom Styles -->
<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Blur effect for mature content images only */
    .mature-image {
        filter: blur(20px);
        transition: filter 0.5s ease;
    }

    .group:hover .mature-image {
        filter: blur(0px);
    }
</style>