@model GalleryCart.Models.ViewModels.UserProfileVM

@{
    ViewData["Title"] = "Artist Profile";
    var activeTab = ViewBag.ActiveTab as string ?? "portfolio";
}

<div class="min-h-screen bg-gray-900 text-white p-4">
    <!-- Artist Profile Section -->
    <div class="max-w-7xl mx-auto mb-8">
        <div class="flex flex-col lg:flex-row gap-6 bg-gray-800 rounded-lg p-6">
            <!-- Artist Avatar -->
            <div class="flex-shrink-0">
                <div class="w-48 h-48 rounded-lg overflow-hidden bg-gray-700">
                    @if (!string.IsNullOrEmpty(Model.UserAvatar))
                    {
                        <img src="@Model.UserAvatar" alt="@Model.UserName" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center">
                            <svg class="w-20 h-20 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                            </svg>
                        </div>
                    }
                </div>
            </div>

            <!-- Artist Information -->
            <div class="flex-grow space-y-6">
                <!-- Basic Info -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Username -->
                    <div>
                        <h3 class="text-lg font-semibold text-white mb-2">Artist Name</h3>
                        <p class="text-gray-400">@Model.UserName</p>
                    </div>

                    <!-- Contact Info -->
                    <div>
                        <h3 class="text-lg font-semibold text-white mb-2">Contact</h3>
                        <p class="text-gray-400">@(Model.ContactInfo ?? "Not provided")</p>
                    </div>

                    <!-- Phone -->
                    <div>
                        <h3 class="text-lg font-semibold text-white mb-2">Phone</h3>
                        <p class="text-gray-400">@(Model.PhoneNumber ?? "Not provided")</p>
                    </div>

                    <!-- Date of Birth -->
                    <div>
                        <h3 class="text-lg font-semibold text-white mb-2">Date of birth</h3>
                        <p class="text-gray-400">
                            @if (Model.UserDOB.HasValue)
                            {
                                @Model.UserDOB.Value.ToString("dd/MM/yyyy")
                            }
                            else
                            {
                                <span>Not provided</span>
                            }
                        </p>
                    </div>
                </div>

                <!-- Professional Info -->
                @if (!string.IsNullOrEmpty(Model.ProfessionSummary))
                {
                    <div>
                        <h3 class="text-lg font-semibold text-white mb-2">Professional Summary</h3>
                        <p class="text-gray-400">@Model.ProfessionSummary</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Skills))
                {
                    <div>
                        <h3 class="text-lg font-semibold text-white mb-2">Skills</h3>
                        <p class="text-gray-400">@Model.Skills</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Software))
                {
                    <div>
                        <h3 class="text-lg font-semibold text-white mb-2">Software & Tools</h3>
                        <p class="text-gray-400">@Model.Software</p>
                    </div>
                }

                <!-- Status Indicators -->
                <div class="flex flex-wrap gap-3">
                    <!-- Job Status -->
                    <div class="flex items-center gap-2">
                        <span class="text-sm font-medium text-gray-300">Availability:</span>
                        @if (Model.IsJobLess)
                        {
                            <span class="badge badge-success badge-sm">Available for Work</span>
                        }
                        else
                        {
                            <span class="badge badge-warning badge-sm">Currently Employed</span>
                        }
                    </div>

                    <!-- Commission Status -->
                    <div class="flex items-center gap-2">
                        <span class="text-sm font-medium text-gray-300">Commissions:</span>
                        @if (Model.CommissionStatus)
                        {
                            <span class="badge badge-accent badge-sm">Open</span>
                        }
                        else
                        {
                            <span class="badge badge-error badge-sm">Closed</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Edit Button (only show for own profile) -->
            @if (Model.IsOwnProfile)
            {
                <div class="flex-shrink-0 self-start">
                    <button class="btn btn-outline btn-sm">Edit Profile</button>
                </div>
            }
        </div>
    </div>

    <!-- Posts Section with Tabs -->
    <div class="max-w-7xl mx-auto">
        <!-- Tabs -->
        <div class="tabs tabs-bordered mb-6">
            <!-- Other Artist Profile: Only Portfolio tab -->
            <a href="?userId=@Model.UserId&tab=portfolio&pageNumber=1&pageSize=@Model.PageSize" 
               class="tab tab-lg tab-active">
                Portfolio
            </a>
        </div>

        <!-- Tab Content -->
        <div class="mb-6">
            @if (activeTab == "portfolio")
            {
                <h2 class="text-2xl font-bold text-white border-b-2 border-white inline-block pb-1">
                    @if (Model.IsOwnProfile)
                    {
                        <span>Your Portfolio</span>
                    }
                    else
                    {
                        <span>@Model.UserName's Portfolio</span>
                    }
                </h2>
                <span class="ml-10">@Model.Posts.Count() Artworks</span>
            }
        </div>

        @if (Model.Posts.Any())
        {
            <!-- Posts Grid -->
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-7 gap-3">
                @foreach (var post in Model.Posts)
                {
                    <div class="relative group cursor-pointer rounded-lg overflow-hidden bg-gray-800 hover:bg-gray-700 transition-colors">
                        <!-- Post Image/Video -->
                        <div class="aspect-square relative">
                            @if (post.IsImage)
                            {
                                <img src="@post.Path" alt="@post.Title" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <div class="w-full h-full bg-gray-700 flex items-center justify-center">
                                    <svg class="w-8 h-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M15 8a3 3 0 10-2.977-2.63l-4.94 2.47a3 3 0 100 4.319l4.94 2.47a3 3 0 10.895-1.789l-4.94-2.47a3.027 3.027 0 000-.74l4.94-2.47C13.456 7.68 14.19 8 15 8z"></path>
                                    </svg>
                                </div>
                            }
                            
                            <!-- Overlay with post info -->
                            <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-70 transition-all duration-300 flex flex-col justify-end p-2">
                                <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                    <h4 class="text-white text-sm font-semibold truncate mb-1">@post.Title</h4>
                                    <p class="text-gray-300 text-xs line-clamp-2">@post.Description</p>
                                    
                                    <!-- Post Stats -->
                                    <div class="flex items-center gap-2 mt-2 text-xs text-gray-400">
                                        <span class="flex items-center gap-1">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 7.933a4 4 0 00-.8 2.4z"></path>
                                            </svg>
                                            @post.LikeCount
                                        </span>
                                        <span class="flex items-center gap-1">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M18 9.5a1.5 1.5 0 11-3 0v-6a1.5 1.5 0 113 0v6zM14 9.667v-5.43a2 2 0 00-1.106-1.79l-.05-.025A4 4 0 0011.057 2H5.64a2 2 0 00-1.962 1.608l-1.2 6A2 2 0 004.44 12H8v4a2 2 0 002 2 1 1 0 001-1v-.667a4 4 0 01.8-2.4l1.4-1.866a4 4 0 00.8-2.4z"></path>
                                            </svg>
                                            @post.DislikeCount
                                        </span>
                                        @if (post.SaleCount > 0)
                                        {
                                            <span class="flex items-center gap-1">
                                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                    <path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4zM18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z"></path>
                                                </svg>
                                                @post.SaleCount
                                            </span>
                                        }
                                    </div>

                                    <!-- Tags -->
                                    @if (post.PostTags.Any())
                                    {
                                        <div class="flex flex-wrap gap-1 mt-2">
                                            @foreach (var tag in post.PostTags.Take(2))
                                            {
                                                <span class="badge badge-xs badge-outline text-gray-300">@tag.TagName</span>
                                            }
                                            @if (post.PostTags.Count() > 2)
                                            {
                                                <span class="badge badge-xs badge-outline text-gray-300">+@(post.PostTags.Count() - 2)</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Mature Content Indicator -->
                            @if (post.IsMature)
                            {
                                <div class="absolute top-2 right-2">
                                    <span class="badge badge-error badge-xs">18+</span>
                                </div>
                            }

                            <!-- Portfolio Indicator (only show in "All Posts" tab) -->
                            @if (post.IsPorfolio && activeTab == "all")
                            {
                                <div class="absolute top-2 left-2">
                                    <span class="badge badge-accent badge-xs">Portfolio</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPostsCount > Model.PageSize)
            {
                <div class="flex justify-center mt-8">
                    <div class="btn-group">
                        @if (Model.CurrentPage > 1)
                        {
                            <a href="?userId=@Model.UserId&tab=@activeTab&pageNumber=@(Model.CurrentPage - 1)&pageSize=@Model.PageSize" class="btn btn-outline">Previous</a>
                        }

                        @{
                            var totalPages = (int)Math.Ceiling((double)Model.TotalPostsCount / Model.PageSize);
                            var startPage = Math.Max(1, Model.CurrentPage - 2);
                            var endPage = Math.Min(totalPages, Model.CurrentPage + 2);
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == Model.CurrentPage)
                            {
                                <span class="btn btn-active">@i</span>
                            }
                            else
                            {
                                <a href="?userId=@Model.UserId&tab=@activeTab&pageNumber=@i&pageSize=@Model.PageSize" class="btn btn-outline">@i</a>
                            }
                        }

                        @if (Model.HasMorePosts)
                        {
                            <a href="?userId=@Model.UserId&tab=@activeTab&pageNumber=@(Model.CurrentPage + 1)&pageSize=@Model.PageSize" class="btn btn-outline">Next</a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <!-- No Posts Message -->
            <div class="text-center py-12">
                <div class="text-gray-400 text-lg">
                    @if (activeTab == "portfolio")
                    {
                        @if (Model.IsOwnProfile)
                        {
                            <p>You don't have any portfolio pieces yet.</p>
                            <p class="text-sm mt-2">Mark your posts as portfolio items to showcase your best work!</p>
                        }
                        else
                        {
                            <p>@Model.UserName doesn't have any portfolio pieces yet.</p>
                        }
                    }
                    else
                    {
                        <p>You don't have any posts yet.</p>
                        <p class="text-sm mt-2">Start creating and sharing your artwork!</p>
                    }
                </div>
            </div>
        }
    </div>
</div>