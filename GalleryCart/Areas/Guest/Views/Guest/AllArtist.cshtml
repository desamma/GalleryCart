@model GalleryCart.Models.ViewModels.AllArtistModel
@{
    ViewData["Title"] = "All Artists";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-base-200 p-4">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-4xl font-bold text-base-content mb-2">All Artists</h1>
                <div class="text-sm breadcrumbs">
                    <ul>
                        <li><a href="/Customer/Home/Index" class="link link-hover">Dashboard</a></li>
                        <li class="text-base-content/60">Artists</li>
                    </ul>
                </div>
            </div>
            <div class="stats shadow bg-base-100">
                <div class="stat place-items-center">
                    <div class="stat-title">Total Artists</div>
                    <div class="stat-value text-2xl">@Model.Artist.Count()</div>
                </div>
                <div class="stat place-items-center">
                    <div class="stat-title">Available</div>
                    <div class="stat-value text-2xl text-success">@Model.Artist.Count(a => a.CommissionStatus)</div>
                </div>
            </div>
        </div>

        <!-- Search and Filter -->
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
            <div class="flex-1">
                <div class="form-control">
                    <div class="input-group">
                        <input type="text" id="searchInput" placeholder="Search artists..." class="input input-bordered w-full" />
                        <button class="btn btn-square" onclick="searchArtists()">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
            <div class="dropdown dropdown-end">
                <div tabindex="0" role="button" class="btn btn-outline">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.207A1 1 0 013 6.5V4z" />
                    </svg>
                    Filter
                </div>
                <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
                    <li><a onclick="filterByStatus('all')">All Artists</a></li>
                    <li><a onclick="filterByStatus('available')">Available for Commission</a></li>
                    <li><a onclick="filterByStatus('unavailable')">Unavailable</a></li>
                </ul>
            </div>
        </div>

        <!-- Artists Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="artistsGrid">
            @foreach (var artist in Model.Artist.Where(u => u.IsArtits && !u.IsBanned))
            {
                <div class="artist-card card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 hover:-translate-y-1" 
                     data-commission-status="@artist.CommissionStatus.ToString().ToLower()" 
                     data-artist-name="@artist.UserName.ToLower()" 
                     data-skills="@artist.Skills.ToLower()">
                    <div class="card-body p-6">
                        <!-- Artist Header -->
                        <div class="flex items-center gap-4 mb-4">
                            <div class="avatar">
                                <div class="w-16 h-16 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
                                    <img src="@(!string.IsNullOrEmpty(artist.UserAvatar) ? artist.UserAvatar : "/images/default-avatar.png")" 
                                         alt="@artist.UserName" />
                                </div>
                            </div>
                            <div class="flex-1">
                                <h3 class="font-bold text-lg text-base-content">@artist.UserName</h3>
                                <p class="text-sm text-base-content/60">@artist.Email</p>
                                <div class="mt-1">
                                    @if (artist.CommissionStatus)
                                    {
                                        <div class="badge badge-success badge-sm">Available for Commission</div>
                                    }
                                    else
                                    {
                                        <div class="badge badge-error badge-sm">Unavailable</div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Professional Summary -->
                        @if (!string.IsNullOrEmpty(artist.ProfessionSummary))
                        {
                            <div class="mb-4">
                                <h4 class="font-semibold text-base-content mb-2">About</h4>
                                <p class="text-base-content/80 text-sm leading-relaxed line-clamp-3">
                                    @artist.ProfessionSummary
                                </p>
                            </div>
                        }

                        <!-- Skills -->
                        @if (!string.IsNullOrEmpty(artist.Skills))
                        {
                            <div class="mb-4">
                                <h4 class="font-semibold text-base-content mb-2">Skills</h4>
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var skill in artist.Skills.Split(',').Take(3))
                                    {
                                        <span class="badge badge-outline badge-sm">@skill.Trim()</span>
                                    }
                                    @if (artist.Skills.Split(',').Length > 3)
                                    {
                                        <span class="badge badge-ghost badge-sm">+@(artist.Skills.Split(',').Length - 3) more</span>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Software -->
                        @if (!string.IsNullOrEmpty(artist.Software))
                        {
                            <div class="mb-4">
                                <h4 class="font-semibold text-base-content mb-2">Software</h4>
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var software in artist.Software.Split(',').Take(3))
                                    {
                                        <span class="badge badge-primary badge-sm">@software.Trim()</span>
                                    }
                                    @if (artist.Software.Split(',').Length > 3)
                                    {
                                        <span class="badge badge-ghost badge-sm">+@(artist.Software.Split(',').Length - 3) more</span>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Member Since -->
                        <div class="text-xs text-base-content/60 mb-4">
                            Member since @artist.CreatedDate?.ToString("MMM yyyy")
                        </div>

                        <!-- Actions -->
                        <div class="card-actions justify-end">
                            <button class="btn btn-outline btn-sm" onclick="viewProfile('@artist.Id')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                                View Profile
                            </button>
                            @if (artist.CommissionStatus)
                            {
                            <a href="@Url.Action("Create", "Commission", new { area = "Customer", artistId = artist.Id })" class="btn btn-primary btn-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                </svg>
                                Request Commission
                            </a>
                            }
                            <a href="@Url.Page("/Chat/Chat", new { area = "Chat" , id = artist.Id})" class="btn btn-ghost btn-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-4 h-4 stroke-current">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                </svg>
                                Message
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Empty State -->
        @if (!Model.Artist.Any(u => u.IsArtits && !u.IsBanned))
        {
            <div class="text-center py-12">
                <div class="text-6xl mb-4">🎨</div>
                <h3 class="text-2xl font-bold text-base-content mb-2">No Artists Found</h3>
                <p class="text-base-content/60">There are no artists available at the moment.</p>
            </div>
        }
    </div>
</div>

<!-- Message Modal -->
<dialog id="messageModal" class="modal">
    <div class="modal-box">
        <form method="dialog">
            <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
        </form>
        <h3 class="font-bold text-lg mb-4">Send Message</h3>
        <div class="form-control">
            <label class="label">
                <span class="label-text">To: <span id="messageArtistName" class="font-semibold"></span></span>
            </label>
            <textarea id="messageContent" class="textarea textarea-bordered h-32" placeholder="Type your message here..."></textarea>
        </div>
        <div class="modal-action">
            <button class="btn btn-primary" onclick="submitMessage()">Send Message</button>
            <form method="dialog">
                <button class="btn">Cancel</button>
            </form>
        </div>
    </div>
</dialog>

<script>
    let currentArtistId = null;

    function searchArtists() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const artistCards = document.querySelectorAll('.artist-card');
        
        artistCards.forEach(card => {
            const artistName = card.dataset.artistName;
            const skills = card.dataset.skills;
            
            if (artistName.includes(searchTerm) || skills.includes(searchTerm)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }

    function filterByStatus(status) {
        const artistCards = document.querySelectorAll('.artist-card');
        
        artistCards.forEach(card => {
            const commissionStatus = card.dataset.commissionStatus;
            
            if (status === 'all' || 
                (status === 'available' && commissionStatus === 'true') ||
                (status === 'unavailable' && commissionStatus === 'false')) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }

    function viewProfile(artistId) {
        window.location.href = `/Artist/Profile/${artistId}`;
    }

    // Search on Enter key
    document.getElementById('searchInput').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            searchArtists();
        }
    });
</script>

<style>
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
