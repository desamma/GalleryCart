@* <link rel="stylesheet" href="~/css/styles.css"> *@
@using GalleryCart.Models.Models
@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Identity
@using GalleryCart.Utilities.Constants

@inject IHttpContextAccessor Accessor
@inject UserManager<User> UserManager

@{
    var userString = Accessor.HttpContext.Session.GetString("CurrentUser");
    User currentUser = null;
    if (userString != null)
    {
        currentUser = System.Text.Json.JsonSerializer.Deserialize<User>(userString);
    }

    bool isAdmin = false;
    bool isArtist = false;
    if (currentUser != null)
    {
        isAdmin = await UserManager.IsInRoleAsync(currentUser, RoleConstants.Admin);
        isArtist = await UserManager.IsInRoleAsync(currentUser, RoleConstants.Artist);
    }
}

@{
    if (currentUser != null)
    {
        <nav class="bg-gray-800">
            <div class="mx-auto max-w-7xl px-2 sm:px-6 lg:px-8">
                <div class="relative flex h-16 items-center justify-between">
                    <div class="absolute inset-y-0 left-0 flex items-center sm:hidden">
                        <!-- Mobile menu button-->
                        @*<button type="button" class="relative inline-flex items-center justify-center rounded-md p-2 text-gray-400 hover:bg-gray-700 hover:text-white focus:ring-2 focus:ring-white focus:outline-hidden focus:ring-inset" aria-controls="mobile-menu" aria-expanded="false">
                            <span class="absolute -inset-0.5"></span>
                            <span class="sr-only">Open main menu</span>
                            <!--
                              Icon when menu is closed.

                              Menu open: "hidden", Menu closed: "block"
                            -->
                            <svg class="block size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                            </svg>
                            <!--
                              Icon when menu is open.

                              Menu open: "block", Menu closed: "hidden"
                            -->
                            <svg class="hidden size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                            </svg>
                        </button>*@
                    </div>
                    <div class="flex flex-1 items-center justify-center sm:items-stretch sm:justify-start">
                        <div class="flex shrink-0 items-center">
                            <img class="h-8 w-auto" src="https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=500" alt="Your Company">
                        </div>
                        <div class="hidden sm:ml-6 sm:block">
                            <div class="flex space-x-4">
                                @if (isArtist)
                                {
                                    <!-- Artist Navigation -->
                                    <a href="#" class="rounded-md bg-gray-900 px-3 py-2 text-sm font-medium text-white" aria-current="page">Artist Dashboard</a>
                                    <a href="#" class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white">My Artworks</a>
                                    <a href="@Url.Page("/Commission/CommissionManagement", new {area = "Artists"})" class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white">Your Commissions</a>
                                    <a href="#" class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white">Sales</a>
                                    <a href="#" class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white">Gallery</a>
                                }
                                else
                                {
                                    <!-- Regular User Navigation -->
                                    <a href="#" class="rounded-md bg-gray-900 px-3 py-2 text-sm font-medium text-white" aria-current="page">Browse Gallery</a>
                                    <a href="#" class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white">My Cart</a>
                                    <a href="@Url.Action("CommissionManagement", "Commission", new { area = "Customer"})" class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white">My Commissions</a>
                                    <a href="#" class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white">Favorites</a>
                                    <a href="@Url.Page("/Artists/AllArtist", new { area = "Customer" })" class="rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white">Artists</a>
                                }

                                @if (isAdmin)
                                {
                                    <!-- Admin Navigation (shown in addition to user/artist nav) -->
                                    <a href="#" class="rounded-md px-3 py-2 text-sm font-medium text-orange-300 hover:bg-orange-700 hover:text-white border border-orange-500">Admin Panel</a>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="absolute inset-y-0 right-0 flex items-center pr-2 sm:static sm:inset-auto sm:ml-6 sm:pr-0">
                        @if (!isArtist)
                        {
                            <!-- Shopping Cart Icon (only for regular users) -->
                            <button type="button" class="relative rounded-full bg-gray-800 p-1 text-gray-400 hover:text-white focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-800 focus:outline-hidden mr-3">
                                <span class="absolute -inset-1.5"></span>
                                <span class="sr-only">View cart</span>
                                <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                                </svg>
                                <!-- Cart item count badge -->
                                <span class="absolute -top-2 -right-2 bg-red-500 text-white text-xs rounded-full h-5 w-5 flex items-center justify-center">3</span>
                            </button>
                        }

                        <!-- Notifications -->
                        <button type="button" class="relative rounded-full bg-gray-800 p-1 text-gray-400 hover:text-white focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-800 focus:outline-hidden">
                            <span class="absolute -inset-1.5"></span>
                            <span class="sr-only">View notifications</span>
                            <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                            </svg>
                        </button>

                        <!-- Profile dropdown -->
                        <div class="dropdown dropdown-end">
                            <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar">
                                <div class="w-10 rounded-full">
                                    <img src="@(currentUser?.UserAvatar ?? GeneralConstants.DefaultAvatar)" alt="@currentUser?.UserName" />
                                </div>
                            </div>
                            <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
                                <li class="menu-title">
                                    <span>@currentUser?.UserName</span>
                                    @if (isArtist)
                                    {
                                        <span class="badge badge-primary badge-sm">Artist</span>
                                    }
                                    @if (isAdmin)
                                    {
                                        <span class="badge badge-warning badge-sm">Admin</span>
                                    }
                                </li>
                                @if (isArtist)
                                {
                                    <li><a asp-action="Edit" asp-controller="Artist">Artist Profile</a></li>
                                    <li><a>Commission Settings</a></li>
                                }
                                else
                                {
                                    <li><a href="@Url.Page("/Profile/UserProfile", new { area = "Customer" })">Your Profile</a></li>
                                    <li><a>Purchase History</a></li>
                                    <li><a>Wishlist</a></li>
                                }
                                <li><a>Settings</a></li>
                                <li><a asp-area="Identity" asp-action="Logout" asp-controller="Auth">Sign out</a></li>
                            </ul>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Mobile menu, show/hide based on menu state. -->
